[sub_resource type="GDScript" id="GDScript_g2je3"]
script/source = "extends CharacterBody3D

@export var is_player_one = false

var _last_mov_direction := Vector3.BACK
const SPEED = 6
const ACCELERATION = 6

@onready var bird = %bird
@onready var spawn01 = %spawn01
@onready var spawn02 = %spawn02

var left_input = \"move_left\"
var right_input = \"move_right\"
var up_input = \"move_up\"
var down_input = \"move_down\"
var shoot_input = \"shoot\"

func _ready():
	add_to_group(\"players\")
	if is_player_one == false:
		left_input += \"_two\"
		right_input += \"_two\"
		up_input += \"_two\"
		down_input += \"_two\"
		shoot_input += \"_two\"
		
func _physics_process(delta):
	var input_dir = Input.get_vector(left_input, right_input, up_input, down_input)
	var direction = (transform.basis * Vector3(input_dir.x, 0, input_dir.y)).normalized()
	
	if direction:
		velocity.x = move_toward(velocity.x, direction.x * SPEED, ACCELERATION * delta)
		velocity.z = move_toward(velocity.z, direction.z * SPEED, ACCELERATION * delta)
	else:
		velocity.x = move_toward(velocity.x, 0, ACCELERATION * delta)
		velocity.z = move_toward(velocity.z, 0, ACCELERATION * delta)

	move_and_slide()
	
	if Input.is_action_pressed(shoot_input) and %Timer.is_stopped():
		shoot_bullet()
	
	if direction.length() > 0.2:
		_last_mov_direction = direction
		var target_angle := Vector3.BACK.signed_angle_to(_last_mov_direction, Vector3.UP)
		bird.global_rotation.y = lerp_angle(bird.rotation.y, target_angle, 5 * delta)

func shoot_bullet():
	const BULLET = preload(\"res://Player/bullet.tscn\")
	var new_bullet = BULLET.instantiate()
	%Marker3D.add_child(new_bullet)
	
	new_bullet.global_transform = %Marker3D.global_transform
	
	%Timer.start()

func take_damage():
	# 1. Get the viewport's active camera
	var cam = get_viewport().get_camera_3d()
	
	# 2. Find the container under that camera
	var hud = cam.get_node(\"SubViewportContainer\")

	# Use 1 for P1, 2 for P2
	if is_player_one == true:
		hud.add_score(2)
	else:
		hud.add_score(1)  
	get_tree().call_group(\"players\", \"respawn\")
	visible = false
	if is_player_one == true:
		global_transform = spawn01.global_transform
	else:
		global_transform = spawn02.global_transform
	
func respawn():
	await get_tree().create_timer(1).timeout
	if is_player_one == true:
		global_transform = spawn01.global_transform
	else:
		global_transform = spawn02.global_transform
	visible = true
"

